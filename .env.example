# Supabase
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_PUBLISHABLE_KEY=eyJhbG...
SUPABASE_SERVICE_KEY=eyJhbG...
SUPABASE_JWT_SIGNING_SECRET=your-jwt-signing-secret
DATABASE_URL=postgresql+asyncpg://postgres.xxxxx:password@aws-0-region.pooler.supabase.com:6543/postgres

# Upstash Redis
UPSTASH_REDIS_REST_URL=https://xxxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=AXxxxx

# Upstash QStash
QSTASH_TOKEN=eyJhbG...
QSTASH_URL=https://qstash-eu-central-1.upstash.io
QSTASH_CURRENT_SIGNING_KEY=sig_xxxxx
QSTASH_NEXT_SIGNING_KEY=sig_xxxxx

# --- Provider API Keys (one per provider) ---
# Only set keys for providers you actually use.
# Key resolution: CHAT_PROVIDER=gemini → looks up GOOGLE_API_KEY
GOOGLE_API_KEY=AIza...
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-...

# --- Chat (hot path) ---
CHAT_PROVIDER=gemini
CHAT_MODEL=gemini-2.5-flash

# --- Extraction (cold path) ---
EXTRACTION_PROVIDER=gemini
EXTRACTION_MODEL=gemini-2.5-flash

# --- Proactive + background jobs ---
BACKGROUND_PROVIDER=gemini
BACKGROUND_MODEL=gemini-2.5-flash

# --- Embeddings ---
EMBEDDING_PROVIDER=gemini
EMBEDDING_MODEL=gemini-embedding-001
# EMBEDDING_DIMENSIONS=768

# App
ENVIRONMENT=development
FRONTEND_URL=http://localhost:5173
API_URL=http://localhost:8000

# Auth
ADMIN_API_KEY=  # generate with: openssl rand -hex 32
EVAL_API_KEY=   # generate with: openssl rand -hex 32

# Push notifications (generate with: npx web-push generate-vapid-keys)
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=

# Langfuse (observability — optional, no-ops if empty)
LANGFUSE_HOST=https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...

# Email inbound webhook (optional)
EMAIL_WEBHOOK_SECRET=

# Stripe (optional)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# CORS (optional, comma-separated additional origins)
# CORS_EXTRA_ORIGINS=https://staging.unspool.life

# Frontend (Vite — prefix with VITE_)
VITE_API_URL=http://localhost:8000
VITE_SUPABASE_URL=https://xxxxx.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=eyJhbG...
VITE_USE_MOCKS=true
VITE_VAPID_PUBLIC_KEY=
