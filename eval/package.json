{
  "name": "unspool-eval",
  "private": true,
  "scripts": {
    "eval": "promptfoo eval",
    "eval:view": "promptfoo view",
    "eval:redteam": "promptfoo redteam run",
    "eval:intent": "promptfoo eval --filter-pattern 'intent_*'",
    "eval:personality": "promptfoo eval --filter-pattern 'personality_*'",
    "eval:functional": "promptfoo eval --filter-pattern 'func_*'",
    "eval:regression": "promptfoo eval --filter-pattern 'reg_*'",
    "cleanup": "curl -X DELETE -H \"X-Admin-Key: $ADMIN_API_KEY\" https://api.unspool.life/admin/eval-cleanup"
  },
  "devDependencies": {
    "promptfoo": "^0.121"
  }
}
