{
  "components": {
    "schemas": {
      "ChatRequest": {
        "properties": {
          "message": {
            "maxLength": 10000,
            "minLength": 1,
            "title": "Message",
            "type": "string"
          },
          "session_id": {
            "maxLength": 100,
            "minLength": 1,
            "title": "Session Id",
            "type": "string"
          },
          "timezone": {
            "anyOf": [
              {
                "maxLength": 50,
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Timezone"
          }
        },
        "required": [
          "message",
          "session_id"
        ],
        "title": "ChatRequest",
        "type": "object"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "title": "Detail",
            "type": "array"
          }
        },
        "title": "HTTPValidationError",
        "type": "object"
      },
      "ProcessMessageRequest": {
        "properties": {
          "embeddings": {
            "default": false,
            "title": "Embeddings",
            "type": "boolean"
          },
          "ingest": {
            "default": false,
            "title": "Ingest",
            "type": "boolean"
          },
          "message_ids": {
            "items": {
              "type": "string"
            },
            "title": "Message Ids",
            "type": "array"
          },
          "tool_calls": {
            "anyOf": [
              {
                "items": {
                  "additionalProperties": true,
                  "type": "object"
                },
                "type": "array"
              },
              {
                "type": "null"
              }
            ],
            "title": "Tool Calls"
          },
          "user_id": {
            "title": "User Id",
            "type": "string"
          }
        },
        "required": [
          "user_id",
          "message_ids"
        ],
        "title": "ProcessMessageRequest",
        "type": "object"
      },
      "PushSubscriptionKeys": {
        "properties": {
          "auth": {
            "title": "Auth",
            "type": "string"
          },
          "p256dh": {
            "title": "P256Dh",
            "type": "string"
          }
        },
        "required": [
          "p256dh",
          "auth"
        ],
        "title": "PushSubscriptionKeys",
        "type": "object"
      },
      "PushSubscriptionRequest": {
        "properties": {
          "endpoint": {
            "title": "Endpoint",
            "type": "string"
          },
          "keys": {
            "$ref": "#/components/schemas/PushSubscriptionKeys"
          }
        },
        "required": [
          "endpoint",
          "keys"
        ],
        "title": "PushSubscriptionRequest",
        "type": "object"
      },
      "StoreTokenRequest": {
        "properties": {
          "provider_refresh_token": {
            "title": "Provider Refresh Token",
            "type": "string"
          },
          "scopes": {
            "default": [],
            "items": {
              "type": "string"
            },
            "title": "Scopes",
            "type": "array"
          }
        },
        "required": [
          "provider_refresh_token"
        ],
        "title": "StoreTokenRequest",
        "type": "object"
      },
      "ValidationError": {
        "properties": {
          "ctx": {
            "title": "Context",
            "type": "object"
          },
          "input": {
            "title": "Input"
          },
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "title": "Location",
            "type": "array"
          },
          "msg": {
            "title": "Message",
            "type": "string"
          },
          "type": {
            "title": "Error Type",
            "type": "string"
          }
        },
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError",
        "type": "object"
      }
    }
  },
